# ─────────────────────────────────────────────────────────────
# FYERS — Data feed, WebSocket, Historical candles, Scalp orders
# ─────────────────────────────────────────────────────────────
APP_ID=YOUR_FYERS_APP_ID
SECRET_KEY=YOUR_FYERS_SECRET
REDIRECT_URL=https://YOUR_EC2_IP:3000/auth/callback
ACCESS_TOKEN=
NIFTY_SPOT_FALLBACK=24000


# ─────────────────────────────────────────────────────────────
# ZERODHA — Order placement (Strategy 1 Live Trade only)
# ─────────────────────────────────────────────────────────────
ZERODHA_API_KEY=YOUR_ZERODHA_API_KEY
ZERODHA_API_SECRET=YOUR_ZERODHA_SECRET
ZERODHA_REDIRECT_URL=https://YOUR_EC2_IP:3000/auth/zerodha/callback
ZERODHA_ACCESS_TOKEN=


# ─────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────
API_SECRET=YOUR_API_SECRET
LOGIN_SECRET=YOUR_LOGIN_SECRET


# ─────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────
PORT=3000
EC2_IP=


# ─────────────────────────────────────────────────────────────
# INSTRUMENT
# ─────────────────────────────────────────────────────────────
INSTRUMENT=NIFTY_OPTIONS
NIFTY_LOT_SIZE=75
LOT_MULTIPLIER=1
STRIKE_OFFSET_CE=0
STRIKE_OFFSET_PE=0
OPTION_EXPIRY_TYPE=weekly
OPTION_EXPIRY_OVERRIDE=


# ─────────────────────────────────────────────────────────────
# STRATEGY 1 — SAR + EMA9 + RSI (15-min, Zerodha orders)
# ─────────────────────────────────────────────────────────────
TRADE_RESOLUTION=15
TRADE_START_TIME=09:15
TRADE_STOP_TIME=15:30
TRADE_EXPIRY_DAY_ONLY=false


# ─────────────────────────────────────────────────────────────
# STRATEGY 1 — RISK CONTROLS
# ─────────────────────────────────────────────────────────────
MAX_DAILY_LOSS=5000
MAX_DAILY_TRADES=20
MAX_SAR_DISTANCE=80
OPT_STOP_PCT=0.15
BREAKEVEN_PTS=25


# ─────────────────────────────────────────────────────────────
# STRATEGY 1 — TRAILING STOP LOSS (3-tier)
# T1: 0→TIER1_UPTO profit → TIER1_GAP trailing gap
# T2: TIER1_UPTO→TIER2_UPTO profit → TIER2_GAP trailing gap
# T3: TIER2_UPTO+ profit → TIER3_GAP trailing gap
# ─────────────────────────────────────────────────────────────
TRAIL_ACTIVATE_PTS=12
TRAIL_TIER1_UPTO=30
TRAIL_TIER2_UPTO=55
TRAIL_TIER1_GAP=40
TRAIL_TIER2_GAP=25
TRAIL_TIER3_GAP=15


# ─────────────────────────────────────────────────────────────
# STRATEGY 1 — SIGNAL FILTERS
# Fine-tune entry conditions for SAR+EMA9+RSI strategy
# ─────────────────────────────────────────────────────────────
RSI_CE_MIN=52
RSI_PE_MAX=48
EMA30_FILTER=true
ADX_MIN_TREND=25
EMA_SLOPE_MIN=6
STRONG_SLOPE=9
STRONG_RSI_CE=58
STRONG_RSI_PE=40
MIN_SAR_DISTANCE=45
MIN_CANDLE_BODY=10
LOGIC3_RSI_MAX=42
LOGIC3_RSI_MIN_CE=58
LOGIC3_SAR_GAP=50


# ─────────────────────────────────────────────────────────────
# STRATEGY 1 — VIX FILTER
# Blocks entries when India VIX is too high (choppy/panic)
# ─────────────────────────────────────────────────────────────
VIX_FILTER_ENABLED=false
VIX_MAX_ENTRY=20
VIX_STRONG_ONLY=16


# ─────────────────────────────────────────────────────────────
# STRATEGY 1 — LIVE TRADE
# Set to true only when Fyers + Zerodha are both logged in
# ─────────────────────────────────────────────────────────────
LIVE_TRADE_ENABLED=false


# ─────────────────────────────────────────────────────────────
# SCALPING — CORE
# Runs in parallel with Strategy 1 via Fyers orders
# ─────────────────────────────────────────────────────────────
SCALP_MODE_ENABLED=true
SCALP_ENABLED=false
SCALP_RESOLUTION=3
SCALP_ENTRY_START=09:21
SCALP_ENTRY_END=14:30
SCALP_EXPIRY_DAY_ONLY=false


# ─────────────────────────────────────────────────────────────
# SCALPING — SL & TRAIL
# SL = Previous candle low (CE) / high (PE), capped at MAX, floored at MIN
# Trail activates at TRAIL_START profit, exits when profit < TRAIL_PCT% of peak
# ─────────────────────────────────────────────────────────────
SCALP_MAX_SL_PTS=25
SCALP_MIN_SL_PTS=8
SCALP_TRAIL_START=200
SCALP_TRAIL_PCT=50
SCALP_TRAIL_TIERS=1000:60,3000:70,5000:80,10000:90


# ─────────────────────────────────────────────────────────────
# SCALPING — EMA9+RSI STRATEGY PARAMS
# ─────────────────────────────────────────────────────────────
SCALP_RSI_CE_MIN=55
SCALP_RSI_PE_MAX=45
SCALP_SL_PTS=12
SCALP_TARGET_PTS=18
SCALP_MIN_BODY=5
SCALP_MIN_SLOPE=2
SCALP_ADX_ENABLED=false
SCALP_ADX_MIN=20


# ─────────────────────────────────────────────────────────────
# SCALPING — V2 ATR LIMITS
# ─────────────────────────────────────────────────────────────
SCALP_ATR_MIN_SL=3
SCALP_ATR_MAX_SL=10


# ─────────────────────────────────────────────────────────────
# SCALPING — BB+CPR STRATEGY PARAMS
# ─────────────────────────────────────────────────────────────
SCALP_CPR_NARROW_PCT=33
SCALP_BB_PERIOD=20
SCALP_BB_STDDEV=1
SCALP_RSI_PERIOD=14
SCALP_RSI_CE_THRESHOLD=55
SCALP_RSI_PE_THRESHOLD=45
SCALP_PSAR_STEP=0.02
SCALP_PSAR_MAX=0.2


# ─────────────────────────────────────────────────────────────
# SCALPING — RISK CONTROLS
# ─────────────────────────────────────────────────────────────
SCALP_MAX_DAILY_TRADES=30
SCALP_MAX_DAILY_LOSS=2000
SCALP_SL_PAUSE_CANDLES=1


# ─────────────────────────────────────────────────────────────
# SCALPING — VIX FILTER (independent from Strategy 1)
# ─────────────────────────────────────────────────────────────
SCALP_VIX_ENABLED=false


# ─────────────────────────────────────────────────────────────
# PAPER TRADE
# ─────────────────────────────────────────────────────────────
PAPER_TRADE_CAPITAL=100000
SCALP_PAPER_CAPITAL=100000


# ─────────────────────────────────────────────────────────────
# BACKTEST
# ─────────────────────────────────────────────────────────────
BACKTEST_FROM=2026-01-01
BACKTEST_TO=2026-03-28
BACKTEST_CAPITAL=100000
BACKTEST_OPTION_SIM=true
BACKTEST_DELTA=0.55
BACKTEST_THETA_DAY=10
BACKTEST_SLIPPAGE_PTS=0


# ─────────────────────────────────────────────────────────────
# CAPITAL PROTECTION
# ─────────────────────────────────────────────────────────────
# Option LTP staleness: warn if no fresh LTP for this many seconds
LTP_STALE_THRESHOLD_SEC=15

# Hard SL: places SL-M order at exchange on every entry.
# Even if the bot crashes, the exchange will fire the stop loss.
HARD_SL_ENABLED=false
HARD_SL_DELTA=0.5


# ─────────────────────────────────────────────────────────────
# TELEGRAM (optional — leave blank to disable)
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TG_TRADE_ENTRY=true
TG_TRADE_EXIT=true
TG_TRADE_SIGNALS=true
TG_SCALP_ENTRY=true
TG_SCALP_EXIT=true


# ─────────────────────────────────────────────────────────────
# CACHE
# ─────────────────────────────────────────────────────────────
CACHE_MAX_DAYS=60
