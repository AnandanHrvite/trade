# ─────────────────────────────────────────────────────────────
# FYERS — Data feed, WebSocket, Historical candles, Scalp orders
# ─────────────────────────────────────────────────────────────
APP_ID=YOUR_FYERS_APP_ID
SECRET_KEY=YOUR_FYERS_SECRET
REDIRECT_URL=https://YOUR_EC2_IP:3000/auth/callback
ACCESS_TOKEN=
NIFTY_SPOT_FALLBACK=24000


# ─────────────────────────────────────────────────────────────
# ZERODHA — Order placement (Strategy 1 / Swing Live only)
# ─────────────────────────────────────────────────────────────
ZERODHA_API_KEY=YOUR_ZERODHA_API_KEY
ZERODHA_API_SECRET=YOUR_ZERODHA_SECRET
ZERODHA_ACCESS_TOKEN=


# ─────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────
API_SECRET=YOUR_API_SECRET
LOGIN_SECRET=YOUR_LOGIN_SECRET


# ─────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────
PORT=3000
EC2_IP=


# ─────────────────────────────────────────────────────────────
# INSTRUMENT
# ─────────────────────────────────────────────────────────────
INSTRUMENT=NIFTY_OPTIONS
NIFTY_LOT_SIZE=75
LOT_MULTIPLIER=1
STRIKE_OFFSET_CE=0
STRIKE_OFFSET_PE=0
OPTION_EXPIRY_TYPE=weekly
OPTION_EXPIRY_OVERRIDE=


# ─────────────────────────────────────────────────────────────
# MARKET TIMING (shared by all engines: live/paper/backtest)
# ─────────────────────────────────────────────────────────────
TRADE_RESOLUTION=15
TRADE_START_TIME=09:15           # market open (engine boot)
TRADE_STOP_TIME=15:30            # EOD square-off + engine shutdown


# ─────────────────────────────────────────────────────────────
# SWING STRATEGY (3/5/15-min) — EMA21 + RSI + SAR — Zerodha live orders
# Same .env values are read by Live, Paper, and Backtest engines.
# ─────────────────────────────────────────────────────────────
SWING_LIVE_ENABLED=false
TRADE_EXPIRY_DAY_ONLY=false
TRADE_ENTRY_START=09:30          # earliest entry time
TRADE_ENTRY_END=14:00            # last entry time (no new entries after)


# ── Swing entry (EMA21 + RSI + SAR) — redefined 2026-05-27 ─────
# CE: RSI in (CE_MIN, CE_MAX) + price ≥ EMA21(OHLC4) + SAR below.  PE: mirror.
RSI_CE_MIN=52                    # CE: RSI must be ABOVE this (momentum floor)
RSI_CE_MAX=80                    # CE: blocked at/above this (overbought)
RSI_PE_MAX=48                    # PE: RSI must be BELOW this (momentum cap)
RSI_PE_MIN=20                    # PE: blocked at/below this (oversold)


# ── Swing stops, exits & risk ──────────────────────────────────
# Stop = previous candle low (CE) / high (PE), trailed candle-by-candle (tighten-only).
MAX_DAILY_LOSS=5000              # ₹ — kill switch (3 consec losses also latch this)
MAX_DAILY_TRADES=6               # session cap
BREAKEVEN_PTS=25                 # +N spot pts in favour → SL moves to entry
OPT_STOP_PCT=0.25                # exit if option premium drops this fraction below entry
SWING_SL_PAUSE_CANDLES=3         # same-side cooldown (candles) after an SL / option-stop hit
SWING_EOD_EXIT_TIME=15:15        # square off any open position at/after this IST time


# ─────────────────────────────────────────────────────────────
# VIX FILTER (per-module; values are read live + paper + backtest)
# Each module: own toggle + max-entry. Strong-only floor is shared.
# VIX_FAIL_MODE applies when VIX data missing (closed=block, open=allow).
# ─────────────────────────────────────────────────────────────
# Swing
VIX_FILTER_ENABLED=false
VIX_MAX_ENTRY=20
VIX_STRONG_ONLY=16
# Scalp (falls back to VIX_*_* defaults when unset)
SCALP_VIX_ENABLED=false
SCALP_VIX_MAX_ENTRY=20
SCALP_VIX_STRONG_ONLY=16
# Price Action (falls back to VIX_*_* defaults when unset)
PA_VIX_ENABLED=false
PA_VIX_MAX_ENTRY=20
PA_VIX_STRONG_ONLY=16
VIX_FAIL_MODE=closed


# ─────────────────────────────────────────────────────────────
# SCALPING — BB+PSAR+RSI strategy via Fyers
# ─────────────────────────────────────────────────────────────
SCALP_MODE_ENABLED=true
SCALP_ENABLED=false
SCALP_RESOLUTION=5          # 3 or 5 (minute candles)
SCALP_ENTRY_START=09:21
SCALP_ENTRY_END=14:30
SCALP_EXPIRY_DAY_ONLY=false


# ── Scalp exit: profit lock + hard stop (spot POINTS) ──────────
# Initial SL = PSAR value at entry (no clamp) — display/sizing only, NOT the stop.
# Profit lock (upside): once peak favourable spot move >= TRIGGER_PTS, exit when it
# gives back below PCT% of peak (ratchets up).
# Hard stop (downside): exit if the trade moves STOP_LOSS_PTS against entry. Set WIDE
# so it only clips deep adverse excursions on failed fades, not the small scalps.
# Both per-tick + points-based so they work even when option P&L is unavailable.
SCALP_PROFIT_LOCK_TRIGGER_PTS=25
SCALP_PROFIT_LOCK_PCT=50
SCALP_STOP_LOSS_PTS=30
# Exit on candle close if price closes back inside the BB (failed breakout)
SCALP_BB_REENTRY_EXIT=true


# ── Scalp BB+PSAR+RSI strategy params ──────────────────────────
SCALP_BB_PERIOD=20
SCALP_BB_STDDEV=1
SCALP_RSI_PERIOD=14
SCALP_RSI_CE_THRESHOLD=70
SCALP_RSI_PE_THRESHOLD=40
SCALP_RSI_TURNING=false
# Confirmation candle: signal candle closes outside BB → next candle must cross its close to enter
SCALP_CONFIRM_CANDLE_ENABLED=true
# Stricter (needs confirm candle on): confirmation candle must CLOSE beyond the signal close AND outside the BB; entry at that close (blocks intra-bar pokes that close back inside)
SCALP_CONFIRM_OUTSIDE_BAND=true
SCALP_PSAR_STEP=0.02
SCALP_PSAR_MAX=0.2
SCALP_MAX_ENTRY_SL_PTS=50
# ADX trend filter (optional): block ALL entries when ADX(14) < SCALP_ADX_MIN.
# Sits out choppy/ranging sessions (the strategy wins in trends, bleeds in chop).
SCALP_ADX_ENABLED=false
SCALP_ADX_MIN=20


# ── Scalp risk controls ────────────────────────────────────────
SCALP_MAX_DAILY_TRADES=30
SCALP_MAX_DAILY_LOSS=2000
SCALP_SL_PAUSE_CANDLES=2
SCALP_CONSEC_SL_EXTRA_PAUSE=2


# ─────────────────────────────────────────────────────────────
# PRICE ACTION — 5-min via Fyers
# ─────────────────────────────────────────────────────────────
PA_MODE_ENABLED=true
PA_ENABLED=false
PA_EXPIRY_DAY_ONLY=false
PA_RESOLUTION=5
PA_ENTRY_START=09:20
PA_ENTRY_END=14:30


# ── PA RSI / ADX confluence ────────────────────────────────────
PA_RSI_PERIOD=14
PA_RSI_CE_MIN=45
PA_RSI_PE_MAX=55
PA_RSI_CAPS_ENABLED=true
PA_RSI_CE_MAX=65
PA_RSI_PE_MIN=25
PA_ADX_ENABLED=true
PA_ADX_MIN=20
PA_ADX_RISING_REQUIRED=true


# ── PA pattern toggles ─────────────────────────────────────────
PA_PATTERN_ENGULFING=true
PA_PATTERN_PINBAR=true
PA_PATTERN_BOS=true
PA_PATTERN_INSIDE_BAR=true
PA_PATTERN_DOUBLE_TOP=false
PA_PATTERN_DOUBLE_BOTTOM=false
PA_PATTERN_ASC_TRIANGLE=false
PA_PATTERN_DESC_TRIANGLE=false


# ── PA pattern parameters ──────────────────────────────────────
PA_MIN_BODY=5
PA_PIN_WICK_RATIO=2
PA_SR_LOOKBACK=30
PA_SR_ZONE_PTS=15


# ── PA trail / SL ──────────────────────────────────────────────
PA_CANDLE_TRAIL_ENABLED=true
PA_CANDLE_TRAIL_BARS=3
PA_TRAIL_START=600
PA_TRAIL_PCT=40
PA_TRAIL_TIERS=1000:50,1500:60,2500:70,4000:80
PA_MAX_SL_PTS=12
PA_MAX_STRUCT_SL_PTS=15
PA_MIN_SL_PTS=8
PA_TIME_STOP_CANDLES=3
PA_TIME_STOP_FLAT_PTS=10
PA_OPT_STOP_PCT=0.15


# ── PA risk controls ───────────────────────────────────────────
PA_MAX_DAILY_TRADES=30
PA_MAX_DAILY_LOSS=2000
PA_SL_PAUSE_CANDLES=2
PA_CONSEC_SL_EXTRA_PAUSE=2


# ─────────────────────────────────────────────────────────────
# PAPER TRADE — starting capital
# ─────────────────────────────────────────────────────────────
SWING_PAPER_CAPITAL=100000
SCALP_PAPER_CAPITAL=100000
PA_PAPER_CAPITAL=100000


# ─────────────────────────────────────────────────────────────
# BACKTEST — option simulation knobs
# (Date range is selected from the UI form, not env.)
# ─────────────────────────────────────────────────────────────
BACKTEST_CAPITAL=100000
BACKTEST_OPTION_SIM=true
BACKTEST_DELTA=0.55
BACKTEST_THETA_DAY=10
BACKTEST_SLIPPAGE_PTS=0


# ─────────────────────────────────────────────────────────────
# CAPITAL PROTECTION (shared across live engines)
# ─────────────────────────────────────────────────────────────
LTP_STALE_THRESHOLD_SEC=15       # warn if option LTP idle for this long
LTP_STALE_FALLBACK_SEC=5         # live falls back to candle close after this
GAP_THRESHOLD_PTS=50             # skip first candle on overnight gap > this
MAX_BID_ASK_SPREAD_PTS=2         # reject entry if option bid-ask wider than this
TIME_STOP_CANDLES=4              # default time-stop window (per-mode overrides win)
TIME_STOP_FLAT_PTS=20            # fires when |pnl| < this after the window
HARD_SL_ENABLED=false            # places SL-M at exchange every entry
HARD_SL_DELTA=0.5                # delta used to translate spot SL → option trigger
CHART_ENABLED=true               # NIFTY chart on status pages


# ─────────────────────────────────────────────────────────────
# TELEGRAM (optional — leave token blank to disable everything)
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TG_ENABLED=true

# Per-mode toggles (paper + live share one toggle per mode)
TG_SWING_STARTED=true
TG_SCALP_STARTED=true
TG_PA_STARTED=true
TG_SWING_ENTRY=true
TG_SCALP_ENTRY=true
TG_PA_ENTRY=true
TG_SWING_EXIT=true
TG_SCALP_EXIT=true
TG_PA_EXIT=true
TG_SWING_SIGNALS=true
TG_SCALP_SIGNALS=false
TG_PA_SIGNALS=false
TG_SWING_DAYREPORT=true
TG_SCALP_DAYREPORT=true
TG_PA_DAYREPORT=true
TG_DAYREPORT_CONSOLIDATED=true   # one combined EOD summary at 15:30 IST


# ─────────────────────────────────────────────────────────────
# CACHE
# ─────────────────────────────────────────────────────────────
CACHE_MAX_DAYS=60
