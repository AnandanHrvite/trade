# ─────────────────────────────────────────────────────────────
# FYERS — Data feed, WebSocket, Historical candles, Scalp orders
# ─────────────────────────────────────────────────────────────
APP_ID=YOUR_FYERS_APP_ID
SECRET_KEY=YOUR_FYERS_SECRET
REDIRECT_URL=https://YOUR_EC2_IP:3000/auth/callback
ACCESS_TOKEN=
NIFTY_SPOT_FALLBACK=24000


# ─────────────────────────────────────────────────────────────
# ZERODHA — Order placement (Strategy 1 Live Trade only)
# ─────────────────────────────────────────────────────────────
ZERODHA_API_KEY=YOUR_ZERODHA_API_KEY
ZERODHA_API_SECRET=YOUR_API_SECRETYOUR_ZERODHA_SECRET
ZERODHA_REDIRECT_URL=https://YOUR_EC2_IP:3000/auth/zerodha/callback
ZERODHA_ACCESS_TOKEN=


# ─────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────
API_SECRET=YOUR_API_SECRET
LOGIN_SECRET=YOUR_LOGIN_SECRET


# ─────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────
PORT=3000
EC2_IP=


# ─────────────────────────────────────────────────────────────
# INSTRUMENT
# ─────────────────────────────────────────────────────────────
INSTRUMENT=NIFTY_OPTIONS
NIFTY_LOT_SIZE=65
LOT_MULTIPLIER=5
STRIKE_OFFSET_CE=0
STRIKE_OFFSET_PE=0


# ─────────────────────────────────────────────────────────────
# STRATEGY 1 — SAR + EMA9 + RSI (15-min, Zerodha orders)
# ─────────────────────────────────────────────────────────────
ACTIVE_STRATEGY=STRATEGY_1
TRADE_RESOLUTION=15
TRADE_START_TIME=09:15
TRADE_STOP_TIME=15:30


# ─────────────────────────────────────────────────────────────
# STRATEGY 1 — RISK CONTROLS
# ─────────────────────────────────────────────────────────────
MAX_DAILY_LOSS=5000
MAX_DAILY_TRADES=20
MAX_SAR_DISTANCE=80
OPT_STOP_PCT=0.15


# ─────────────────────────────────────────────────────────────
# STRATEGY 1 — BREAKEVEN STOP
# After +25pt move in favor, SL moves to entry price (zero risk)
# This is the game-changer: converts reversals to zero-loss
# ─────────────────────────────────────────────────────────────
BREAKEVEN_PTS=25


# ─────────────────────────────────────────────────────────────
# STRATEGY 1 — TRAILING STOP LOSS (3-tier)
# T1: 0-30pt profit → 40pt gap (room to breathe)
# T2: 30-55pt profit → 25pt gap (locking gains)
# T3: 55pt+ profit → 15pt gap (maximum capture)
# ─────────────────────────────────────────────────────────────
TRAIL_ACTIVATE_PTS=12
TRAIL_TIER1_UPTO=30
TRAIL_TIER2_UPTO=55
TRAIL_TIER1_GAP=40
TRAIL_TIER2_GAP=25
TRAIL_TIER3_GAP=15


# ─────────────────────────────────────────────────────────────
# STRATEGY 1 — VIX FILTER (independent from scalp)
# Disabled for Strategy 1 — EMA30 trend filter handles it
# ─────────────────────────────────────────────────────────────
VIX_FILTER_ENABLED=false
VIX_MAX_ENTRY=20
VIX_STRONG_ONLY=16


# ─────────────────────────────────────────────────────────────
# STRATEGY 1 — LIVE TRADE
# Set to true only when Fyers + Zerodha are both logged in
# Paper trade first for 2-3 weeks before enabling!
# ─────────────────────────────────────────────────────────────
LIVE_TRADE_ENABLED=false


# ─────────────────────────────────────────────────────────────
# SCALPING STRATEGY — SAR + EMA9 cross + RSI (3-min, Fyers orders)
# ─────────────────────────────────────────────────────────────
SCALP_MODE_ENABLED=true
SCALP_ENABLED=false
SCALP_RESOLUTION=3


# ─────────────────────────────────────────────────────────────
# SCALPING — SL & TARGET (ATR-based)
# SL = SAR value, capped at ATR_MAX_SL
# Target = ATR × 10 (effectively disabled — trail handles exits)
# ─────────────────────────────────────────────────────────────
SCALP_USE_ATR_SL=true
SCALP_ATR_SL_MULT=1.2
SCALP_ATR_TGT_MULT=10.0
SCALP_ATR_MIN_SL=3
SCALP_ATR_MAX_SL=15
SCALP_SL_PTS=15
SCALP_TARGET_PTS=20


# ─────────────────────────────────────────────────────────────
# SCALPING — BREAKEVEN + TRAIL
# Breakeven at +4pt, trail activates at +4pt with 3pt gap
# ─────────────────────────────────────────────────────────────
SCALP_BREAKEVEN_PTS=4
SCALP_TRAIL_AFTER=4
SCALP_TRAIL_GAP=3


# ─────────────────────────────────────────────────────────────
# SCALPING — ENTRY FILTERS
# ─────────────────────────────────────────────────────────────
SCALP_RSI_CE_MIN=50
SCALP_RSI_PE_MAX=50
SCALP_MIN_BODY=3
SCALP_MIN_SLOPE=1
SCALP_ADX_ENABLED=false
SCALP_ADX_MIN=20


# ─────────────────────────────────────────────────────────────
# SCALPING — RISK CONTROLS
# ─────────────────────────────────────────────────────────────
SCALP_MAX_DAILY_TRADES=30
SCALP_MAX_DAILY_LOSS=2000
SCALP_SL_PAUSE_CANDLES=1
SCALP_TIME_STOP_CANDLES=12


# ─────────────────────────────────────────────────────────────
# SCALPING — VIX FILTER (independent from Strategy 1)
# ─────────────────────────────────────────────────────────────
SCALP_VIX_ENABLED=false


# ─────────────────────────────────────────────────────────────
# PAPER TRADE
# ─────────────────────────────────────────────────────────────
PAPER_TRADE_CAPITAL=100000


# ─────────────────────────────────────────────────────────────
# BACKTEST
# ─────────────────────────────────────────────────────────────
BACKTEST_FROM=2026-01-01
BACKTEST_TO=2026-03-28
BACKTEST_CAPITAL=100000
BACKTEST_OPTION_SIM=true
BACKTEST_DELTA=0.55
BACKTEST_THETA_DAY=10


# ─────────────────────────────────────────────────────────────
# TELEGRAM (optional — leave blank to disable)
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
