# ─────────────────────────────────────────────────────────────────
# Palani Andawar Trading App — .env
# Copy this file to .env and fill in your actual values.
# ─────────────────────────────────────────────────────────────────


# ── FYERS API ─────────────────────────────────────────────────────
# Get these from https://myapi.fyers.in → My Apps
APP_ID=XJ4520-100
SECRET_KEY=ABCD1234EFGH5678IJKL9012MNOP3456
REDIRECT_URL=http://localhost:3000/auth/callback


# ── ZERODHA KITE CONNECT ──────────────────────────────────────────
# Only needed for Live Trade. Leave blank for paper trade / backtest only.
# Get these from https://developers.kite.trade → Your Apps
ZERODHA_API_KEY=abcdef1234567890
ZERODHA_API_SECRET=abcdefghijklmnopqrstuvwxyz123456


# ── APP SECURITY ──────────────────────────────────────────────────
# Any random string — just don't leave it as the default
API_SECRET=palani2024xTrade!secure


# ── INSTRUMENT ────────────────────────────────────────────────────
# NIFTY_OPTIONS  → buys CE or PE option (BUY only, no shorting)
# NIFTY_FUTURES  → trades NIFTY futures (CE=LONG, PE=SHORT)
INSTRUMENT=NIFTY_OPTIONS

# 0 = ATM | 50 = 1 OTM | -50 = 1 ITM
STRIKE_OFFSET=0

# 1 lot = 75 qty for NIFTY options
LOT_MULTIPLIER=1


# ── TRADING TIMES ─────────────────────────────────────────────────
TRADE_RESOLUTION=15
TRADE_START_TIME=09:15
TRADE_STOP_TIME=15:30


# ── RISK CONTROLS ─────────────────────────────────────────────────
# Stop all entries for the day once loss hits ₹5000
MAX_DAILY_LOSS=5000

# Max 10 trades per session
MAX_DAILY_TRADES=10

# Option premium fallback stop (15% drop from entry LTP)
# Only fires if spot-based SL doesn't trigger first
OPT_STOP_PCT=0.15


# ── TRAILING STOP LOSS ────────────────────────────────────────────
# Minimum points gain before trail activates.
# Actual threshold per trade = max(15, 25% of SAR gap at entry)
TRAIL_ACTIVATE_PTS=15

# T1: 0–40pt profit   → 60pt gap (wide — early move needs room)
# T2: 40–70pt profit  → 40pt gap (tightening)
# T3: 70pt+ profit    → 30pt gap (locking in large gains)
TRAIL_TIER1_UPTO=40
TRAIL_TIER2_UPTO=70
TRAIL_TIER1_GAP=60
TRAIL_TIER2_GAP=40
TRAIL_TIER3_GAP=30


# ── PAPER TRADE ───────────────────────────────────────────────────
PAPER_TRADE_CAPITAL=100000


# ── BACKTEST DEFAULTS ─────────────────────────────────────────────
BACKTEST_FROM=2024-01-01
BACKTEST_TO=2024-12-31
BACKTEST_CAPITAL=100000


# ── LIVE TRADE GATE ───────────────────────────────────────────────
# Keep false until you are ready. Flip to true only on live day.
LIVE_TRADE_ENABLED=false


# ── TELEGRAM NOTIFICATIONS (optional) ────────────────────────────
TELEGRAM_BOT_TOKEN=7412365890:AAFxyz_abcDEF123ghiJKL456mnoP789qrs
TELEGRAM_CHAT_ID=123456789


# ── SERVER (optional) ─────────────────────────────────────────────
PORT=3000
# EC2_IP=43.205.26.92

//TEST COMMIT 