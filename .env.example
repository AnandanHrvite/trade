# ─────────────────────────────────────────────────────────────
# FYERS — Data feed, WebSocket, Historical candles
# ─────────────────────────────────────────────────────────────
APP_ID=1111-100
SECRET_KEY=11111
REDIRECT_URL=http://127.0.0.1:3000/auth/callback
ACCESS_TOKEN=
NIFTY_SPOT_FALLBACK=24000


# ─────────────────────────────────────────────────────────────
# ZERODHA — Order placement (Live Trade only)
# ─────────────────────────────────────────────────────────────
ZERODHA_API_KEY=1111111
ZERODHA_API_SECRET=11111111
ZERODHA_REDIRECT_URL=http://localhost:3000/auth/zerodha/callback
ZERODHA_ACCESS_TOKEN=


# ─────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────
API_SECRET=


# ─────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────
PORT=3000
EC2_IP=


# ─────────────────────────────────────────────────────────────
# INSTRUMENT
# ─────────────────────────────────────────────────────────────
INSTRUMENT=NIFTY_OPTIONS
STRIKE_OFFSET=0
LOT_MULTIPLIER=1


# ─────────────────────────────────────────────────────────────
# STRATEGY
# ─────────────────────────────────────────────────────────────
ACTIVE_STRATEGY=STRATEGY_1


# ─────────────────────────────────────────────────────────────
# TIMEFRAME
# ─────────────────────────────────────────────────────────────
TRADE_RESOLUTION=15
TRADE_START_TIME=09:15
TRADE_STOP_TIME=15:30


# ─────────────────────────────────────────────────────────────
# RISK CONTROLS
# ─────────────────────────────────────────────────────────────
MAX_DAILY_LOSS=5000
MAX_DAILY_TRADES=10
OPT_STOP_PCT=0.15


# ─────────────────────────────────────────────────────────────
# TRAILING STOP LOSS
# Trail activates at: max(TRAIL_ACTIVATE_PTS, 25% of SAR gap at entry)
# ─────────────────────────────────────────────────────────────
TRAIL_ACTIVATE_PTS=15
TRAIL_TIER1_UPTO=25
TRAIL_TIER2_UPTO=50
TRAIL_TIER1_GAP=20
TRAIL_TIER2_GAP=30
TRAIL_TIER3_GAP=20


# ─────────────────────────────────────────────────────────────
# PAPER TRADE
# ─────────────────────────────────────────────────────────────
PAPER_TRADE_CAPITAL=100000


# ─────────────────────────────────────────────────────────────
# BACKTEST
# ─────────────────────────────────────────────────────────────
BACKTEST_FROM=2026-01-01
BACKTEST_TO=2026-02-28
BACKTEST_CAPITAL=100000
BACKTEST_OPTION_SIM=true
BACKTEST_DELTA=0.55
BACKTEST_THETA_DAY=10


# ─────────────────────────────────────────────────────────────
# LIVE TRADE
# Set to true only when Fyers + Zerodha are both logged in
# ─────────────────────────────────────────────────────────────
LIVE_TRADE_ENABLED=false


# ─────────────────────────────────────────────────────────────
# TELEGRAM (optional — leave blank to disable)
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=