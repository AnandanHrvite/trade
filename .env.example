# ─────────────────────────────────────────────────────────────
# FYERS — Data feed, WebSocket, Historical candles, Scalp orders
# ─────────────────────────────────────────────────────────────
APP_ID=YOUR_FYERS_APP_ID
SECRET_KEY=YOUR_FYERS_SECRET
REDIRECT_URL=https://YOUR_EC2_IP:3000/auth/callback
ACCESS_TOKEN=
NIFTY_SPOT_FALLBACK=24000


# ─────────────────────────────────────────────────────────────
# ZERODHA — Order placement (Strategy 1 / Swing Live only)
# ─────────────────────────────────────────────────────────────
ZERODHA_API_KEY=YOUR_ZERODHA_API_KEY
ZERODHA_API_SECRET=YOUR_ZERODHA_SECRET
ZERODHA_ACCESS_TOKEN=


# ─────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────
API_SECRET=YOUR_API_SECRET
LOGIN_SECRET=YOUR_LOGIN_SECRET


# ─────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────
PORT=3000
EC2_IP=


# ─────────────────────────────────────────────────────────────
# INSTRUMENT
# ─────────────────────────────────────────────────────────────
INSTRUMENT=NIFTY_OPTIONS
NIFTY_LOT_SIZE=75
LOT_MULTIPLIER=1
STRIKE_OFFSET_CE=0
STRIKE_OFFSET_PE=0
OPTION_EXPIRY_TYPE=weekly
OPTION_EXPIRY_OVERRIDE=


# ─────────────────────────────────────────────────────────────
# MARKET TIMING (shared by all engines: live/paper/backtest)
# ─────────────────────────────────────────────────────────────
TRADE_RESOLUTION=15
TRADE_START_TIME=09:15           # market open (engine boot)
TRADE_STOP_TIME=15:30            # EOD square-off + engine shutdown


# ─────────────────────────────────────────────────────────────
# SWING STRATEGY (15-min) — SAR + EMA9 + RSI — Zerodha live orders
# Same .env values are read by Live, Paper, and Backtest engines.
# ─────────────────────────────────────────────────────────────
SWING_LIVE_ENABLED=false
TRADE_EXPIRY_DAY_ONLY=false
TRADE_ENTRY_START=09:30          # earliest entry time
TRADE_ENTRY_END=14:00            # last entry time (no new entries after)


# ── Swing risk caps ────────────────────────────────────────────
MAX_DAILY_LOSS=5000              # ₹ — kill switch (3 consec losses also latch this)
MAX_DAILY_TRADES=6               # session cap (was 20 — chop-day overtrading guard)
OPT_STOP_PCT=0.25                # fallback SL = 25% of option premium
BREAKEVEN_PTS=25                 # underlying move that drags SL to entry


# ── Swing initial SL (capped, structural) ──────────────────────
SWING_USE_PREV_CANDLE_SL=true    # initial SL = prev-candle low (CE) / high (PE)
SWING_MAX_INITIAL_SL_PTS=50      # hard cap — never wider than 50pt from entry
SWING_MIN_INITIAL_SL_PTS=15      # floor — never tighter than 15pt (no doji-suicide SL)
MAX_SAR_DISTANCE=80              # reject entries whose SAR-based SL exceeds this
MIN_SAR_DISTANCE=45              # reject entries whose SL is too tight (noise)


# ── Swing prev-candle structural trail (candle-by-candle, profit-only) ──────────
# After each candle close, if trade is in profit, trail SL to that candle's low (CE)
# / high (PE) ± buffer. Tighten-only; composes with SAR + tier trail (takes whichever
# is tightest). Disabled by default — backtest first.
SWING_PREV_CANDLE_TRAIL_ENABLED=false       # master toggle
SWING_PREV_CANDLE_TRAIL_ACTIVATE_PTS=15     # min profit before this trail engages
SWING_PREV_CANDLE_TRAIL_BUFFER_PTS=2        # padding under prev low / above prev high
SWING_PREV_CANDLE_TRAIL_MAX_GAP=35          # skip wide bars — protects against loosening on volatile candles


# ── Swing entry filters ────────────────────────────────────────
EMA30_FILTER=true                # block counter-trend (CE under EMA30 / PE over)
ADX_MIN_TREND=25                 # min ADX — below = chop, block entry
EMA_TOUCH_MAX=20                 # max distance from EMA9 to count as touch
EMA_SLOPE_MIN=6                  # min EMA9 slope for any entry (pts vs prev)
MIN_CANDLE_BODY=10               # filter dojis
RSI_CE_MIN=52                    # bullish momentum threshold for CE
RSI_PE_MAX=48                    # bearish momentum threshold for PE


# ── Swing STRONG-vs-MARGINAL classification ────────────────────
STRONG_SLOPE=9                   # slope >= this → STRONG (intra-candle entry)
STRONG_RSI_CE=58                 # RSI >= this with STRONG slope → STRONG CE
STRONG_RSI_PE=40                 # RSI <= this with STRONG slope → STRONG PE


# ── Swing Logic3 (SAR-lag override path) ───────────────────────
LOGIC3_RSI_MAX=46                # PE override when SAR still bull
LOGIC3_RSI_MIN_CE=53             # CE override when SAR still bear
LOGIC3_SAR_GAP=30                # SAR must lag price by this many pts


# ── Swing trailing SL (3-tier) ─────────────────────────────────
# T1: 0→TIER1_UPTO  → TIER1_GAP    (widest, give room early)
# T2: TIER1→TIER2   → TIER2_GAP
# T3: TIER2+        → TIER3_GAP    (tightest, lock profit)
TRAIL_ACTIVATE_PTS=12
TRAIL_TIER1_UPTO=30
TRAIL_TIER1_GAP=40
TRAIL_TIER2_UPTO=55
TRAIL_TIER2_GAP=25
TRAIL_TIER3_GAP=15


# ─────────────────────────────────────────────────────────────
# VIX FILTER (per-module; values are read live + paper + backtest)
# Each module: own toggle + max-entry. Strong-only floor is shared.
# VIX_FAIL_MODE applies when VIX data missing (closed=block, open=allow).
# ─────────────────────────────────────────────────────────────
# Swing
VIX_FILTER_ENABLED=false
VIX_MAX_ENTRY=20
VIX_STRONG_ONLY=16
# Scalp (falls back to VIX_*_* defaults when unset)
SCALP_VIX_ENABLED=false
SCALP_VIX_MAX_ENTRY=20
SCALP_VIX_STRONG_ONLY=16
# Price Action (falls back to VIX_*_* defaults when unset)
PA_VIX_ENABLED=false
PA_VIX_MAX_ENTRY=20
PA_VIX_STRONG_ONLY=16
VIX_FAIL_MODE=closed


# ─────────────────────────────────────────────────────────────
# SCALPING — BB+CPR strategy via Fyers
# ─────────────────────────────────────────────────────────────
SCALP_MODE_ENABLED=true
SCALP_ENABLED=false
SCALP_RESOLUTION=5
SCALP_ENTRY_START=09:21
SCALP_ENTRY_END=14:30
SCALP_EXPIRY_DAY_ONLY=false


# ── Scalp SL / Trail ───────────────────────────────────────────
SCALP_MAX_SL_PTS=25
SCALP_MIN_SL_PTS=8
SCALP_TRAIL_START=350
SCALP_TRAIL_PCT=65
SCALP_TRAIL_TIERS=500:55,1000:60,3000:70,5000:80,10000:90
SCALP_TRAIL_GRACE_SECS=0


# ── Scalp BB+CPR strategy params ───────────────────────────────
SCALP_CPR_NARROW_PCT=33
SCALP_BB_PERIOD=20
SCALP_BB_STDDEV=1
SCALP_RSI_PERIOD=14
SCALP_RSI_CE_THRESHOLD=55
SCALP_RSI_PE_THRESHOLD=45
SCALP_PSAR_STEP=0.02
SCALP_PSAR_MAX=0.2
SCALP_BB_SQUEEZE_FILTER=true
SCALP_BB_MIN_WIDTH_PCT=0.15
SCALP_REQUIRE_APPROACH=false
SCALP_MIN_BODY_RATIO=0
SCALP_TREND_FILTER=true
SCALP_TREND_MOMENTUM_LOOKBACK=5
SCALP_TREND_MOMENTUM_PCT=0.15
SCALP_TREND_MID_SLOPE_LOOKBACK=3
SCALP_ACTIVITY_FILTER=false
SCALP_ACTIVITY_FILTER_RATIO=0.5


# ── Scalp risk controls ────────────────────────────────────────
SCALP_MAX_DAILY_TRADES=30
SCALP_MAX_DAILY_LOSS=2000
SCALP_SL_PAUSE_CANDLES=2
SCALP_CONSEC_SL_EXTRA_PAUSE=2


# ─────────────────────────────────────────────────────────────
# PRICE ACTION — 5-min via Fyers
# ─────────────────────────────────────────────────────────────
PA_MODE_ENABLED=true
PA_ENABLED=false
PA_EXPIRY_DAY_ONLY=false
PA_RESOLUTION=5
PA_ENTRY_START=09:20
PA_ENTRY_END=14:30


# ── PA RSI / ADX confluence ────────────────────────────────────
PA_RSI_PERIOD=14
PA_RSI_CE_MIN=45
PA_RSI_PE_MAX=55
PA_RSI_CAPS_ENABLED=true
PA_RSI_CE_MAX=65
PA_RSI_PE_MIN=25
PA_ADX_ENABLED=true
PA_ADX_MIN=20
PA_ADX_RISING_REQUIRED=true
PA_ADX_DIRECTIONAL=true


# ── PA pattern toggles ─────────────────────────────────────────
PA_PATTERN_ENGULFING=true
PA_PATTERN_PINBAR=true
PA_PATTERN_BOS=true
PA_PATTERN_INSIDE_BAR=true
PA_PATTERN_DOUBLE_TOP=false
PA_PATTERN_DOUBLE_BOTTOM=false
PA_PATTERN_ASC_TRIANGLE=false
PA_PATTERN_DESC_TRIANGLE=false


# ── PA pattern parameters ──────────────────────────────────────
PA_MIN_BODY=5
PA_PIN_WICK_RATIO=2
PA_SR_LOOKBACK=30
PA_SR_ZONE_PTS=15


# ── PA trail / SL ──────────────────────────────────────────────
PA_CANDLE_TRAIL_ENABLED=true
PA_CANDLE_TRAIL_BARS=3
PA_TRAIL_START=600
PA_TRAIL_PCT=40
PA_TRAIL_TIERS=1000:50,1500:60,2500:70,4000:80
PA_MAX_SL_PTS=12
PA_MAX_STRUCT_SL_PTS=15
PA_MIN_SL_PTS=8
PA_TIME_STOP_CANDLES=3
PA_TIME_STOP_FLAT_PTS=10
PA_BREAKEVEN_TRIGGER=300
PA_BREAKEVEN_BUFFER=1
PA_OPT_STOP_PCT=0.15


# ── PA risk controls ───────────────────────────────────────────
PA_MAX_DAILY_TRADES=30
PA_MAX_DAILY_LOSS=2000
PA_SL_PAUSE_CANDLES=2
PA_CONSEC_SL_EXTRA_PAUSE=2


# ─────────────────────────────────────────────────────────────
# PAPER TRADE — starting capital
# ─────────────────────────────────────────────────────────────
SWING_PAPER_CAPITAL=100000
SCALP_PAPER_CAPITAL=100000
PA_PAPER_CAPITAL=100000


# ─────────────────────────────────────────────────────────────
# BACKTEST — option simulation knobs
# (Date range is selected from the UI form, not env.)
# ─────────────────────────────────────────────────────────────
BACKTEST_CAPITAL=100000
BACKTEST_OPTION_SIM=true
BACKTEST_DELTA=0.55
BACKTEST_THETA_DAY=10
BACKTEST_SLIPPAGE_PTS=0


# ─────────────────────────────────────────────────────────────
# CAPITAL PROTECTION (shared across live engines)
# ─────────────────────────────────────────────────────────────
LTP_STALE_THRESHOLD_SEC=15       # warn if option LTP idle for this long
LTP_STALE_FALLBACK_SEC=5         # live falls back to candle close after this
GAP_THRESHOLD_PTS=50             # skip first candle on overnight gap > this
MAX_BID_ASK_SPREAD_PTS=2         # reject entry if option bid-ask wider than this
TIME_STOP_CANDLES=4              # default time-stop window (per-mode overrides win)
TIME_STOP_FLAT_PTS=20            # fires when |pnl| < this after the window
HARD_SL_ENABLED=false            # places SL-M at exchange every entry
HARD_SL_DELTA=0.5                # delta used to translate spot SL → option trigger
CHART_ENABLED=true               # NIFTY chart on status pages


# ─────────────────────────────────────────────────────────────
# TELEGRAM (optional — leave token blank to disable everything)
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TG_ENABLED=true

# Per-mode toggles (paper + live share one toggle per mode)
TG_SWING_STARTED=true
TG_SCALP_STARTED=true
TG_PA_STARTED=true
TG_SWING_ENTRY=true
TG_SCALP_ENTRY=true
TG_PA_ENTRY=true
TG_SWING_EXIT=true
TG_SCALP_EXIT=true
TG_PA_EXIT=true
TG_SWING_SIGNALS=true
TG_SCALP_SIGNALS=false
TG_PA_SIGNALS=false
TG_SWING_DAYREPORT=true
TG_SCALP_DAYREPORT=true
TG_PA_DAYREPORT=true
TG_DAYREPORT_CONSOLIDATED=true   # one combined EOD summary at 15:30 IST
TG_WEEKLY_REPORT=true            # weekly summary every Monday 20:00 IST (last 7d vs prior 7d)


# ─────────────────────────────────────────────────────────────
# CACHE
# ─────────────────────────────────────────────────────────────
CACHE_MAX_DAYS=60
